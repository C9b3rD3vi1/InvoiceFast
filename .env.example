# InvoiceFast Environment Variables

# ==================== SERVER ====================
PORT=8082
APP_ENV=development  # Use "production" for production

# ==================== DATABASE ====================
DB_DRIVER=sqlite3  # Use "postgres" for production
DB_DSN=./data/invoicefast.db
# For PostgreSQL:
# DB_DRIVER=postgres
# DB_DSN=host=postgres user=invoicefast password=change_me dbname=invoicefast port=5432 sslmode=disable

# ==================== JWT AUTH ====================
JWT_SECRET=change-this-to-a-secure-random-string-in-production-min-32-chars

# ==================== INTASEND (M-Pesa) ====================
INTASEND_PUBLISHABLE_KEY=your_publishable_key
INTASEND_SECRET_KEY=your_secret_key
INTASEND_API_URL=https://sandbox.intasend.com  # Use "https://api.intasend.com" for production
INTASEND_WEBHOOK_SECRET=your_webhook_secret

# ==================== EMAIL (SMTP) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password  # Use App Password for Gmail
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=InvoiceFast

# ==================== CALLBACKS ====================
CALLBACK_URL=https://yourdomain.com/api/v1/webhook/intasend

# ==================== KRA e-TIMS (Kenya Tax) ====================
# Leave empty for development - KRA integration is optional
# M-Pesa
MPESA_ENABLED=true
MPESA_CONSUMER_KEY=xxx
MPESA_CONSUMER_SECRET=xxx
MPESA_BUSINESS_SHORT_CODE=xxx
MPESA_PASS_KEY=xxx
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/webhook/mpesa
MPESA_ENVIRONMENT=sandbox

# KRA
KRA_ENABLED=true
KRA_API_URL=https://api.kra.go.ke
KRA_API_KEY=xxx
KRA_PRIVATE_KEY=xxx
KRA_DEVICE_ID=xxx
KRA_BRANCH_ID=xxx

# ==================== WHATSAPP BUSINESS ====================
# Leave empty for development - WhatsApp is optional
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ==================== REDIS (Optional) ====================
REDIS_URL=redis://redis:6379

# ==================== PRODUCTION SETTINGS ====================
# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60s

# Logging
LOG_LEVEL=info
LOG_FILE=/app/logs/invoicefast.log

# Security
ALLOWED_ORIGINS=https://invoice.simuxtech.com,https://app.invoicefast.com

# ==================== ENCRYPTION KEY (CRITICAL) ====================
# Must be at least 32 characters. Used for encrypting sensitive data at rest.
ENCRYPTION_KEY=change-this-to-a-secure-32-character-string!!!!

# ==================== DATABASE POOL SETTINGS ====================
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m
DB_QUERY_TIMEOUT=10s

# ==================== JWT EXPIRY ====================
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# ==================== STRIPE ====================
# Leave empty for development - Stripe is optional
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ==================== SMS (Africa's Talking / Twilio) ====================
SMS_ENABLED=false
SMS_PROVIDER=africastalking  # Options: africastalking, twilio, bulk
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=INVOICEFAST
SMS_ENDPOINT=

# ==================== WHATSAPP (Additional) ====================
WHATSAPP_ENABLED=false
WHATSAPP_API_KEY=
WHATSAPP_API_SECRET=
WHATSAPP_PHONE_NUMBER=

# ==================== QUICKBOOKS INTEGRATION ====================
QUICKBOOKS_ENABLED=false
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_REDIRECT_URI=

# ==================== S3 BACKUP ====================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *
BACKUP_LOCAL_DIR=./data/backups
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_RETENTION_DAYS=30

# ==================== TIMEOUTS ====================
TIMEOUT_DB_QUERY=10s
TIMEOUT_EXTERNAL_API=30s
TIMEOUT_REQUEST=60s
TIMEOUT_SHUTDOWN=30s

# ==================== CORS ====================
CORS_ENABLED=true
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key,Accept,Origin
EXPOSE_HEADERS=Content-Length,X-Request-ID
CORS_MAX_AGE=86400

# ==================== RATE LIMITING (Advanced) ====================
RATE_LIMIT_BURST=20
RATE_LIMIT_CLEANUP=5m

# ==================== REDIS (Advanced) ====================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== INTASEND (Advanced) ====================
INTASEND_API_KEY=
INTASEND_PUBLIC_KEY=
INTASEND_CONNECT_TIMEOUT=10s
INTASEND_READ_TIMEOUT=30s

# ==================== M-PESA (Advanced) ====================
MPESA_SECURITY_CREDENTIAL=
MPESA_QUEUE_TIMEOUT=30s
MPESA_RESULT_URL=

# ==================== KRA (Advanced) ====================
KRA_BRANCH_CODE=
KRA_CERT_SERIAL=

# ==================== MAIL SENDERS ====================
MAIL_SENDER_DOMAIN=invoicefast.app
MAIL_SENDER_BILLING_NAME=InvoiceFast Billing
MAIL_SENDER_BILLING_EMAIL=billing@invoicefast.app
MAIL_SENDER_INFO_NAME=InvoiceFast
MAIL_SENDER_INFO_EMAIL=info@invoicefast.app
MAIL_SENDER_NOREPLY_NAME=InvoiceFast
MAIL_SENDER_NOREPLY_EMAIL=noreply@invoicefast.app

# ==================== BASE URL ====================
BASE_URL=https://invoice.simuxtech.com

# ==================== DEFAULT CURRENCY ====================
DEFAULT_CURRENCY=KES
