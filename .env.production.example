# InvoiceFast Production Environment Template
# Copy this to .env and fill in the values

# ==================== SERVER ====================
PORT=8082
GIN_MODE=production

# ==================== DATABASE (POSTGRESQL) ====================
# Use PostgreSQL for production!
DB_DRIVER=postgres
DB_DSN=postgresql://user:password@localhost:5432/invoicefast?sslmode=disable

# Connection pool settings (adjust based on traffic)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m
DB_QUERY_TIMEOUT=10s

# ==================== SECURITY KEYS (CRITICAL) ====================
# Generate secure random values (at least 64 characters for JWT, 32 for encryption)
JWT_SECRET=<generate-a-secure-64-character-random-string>
ENCRYPTION_KEY=<generate-a-secure-32-character-random-string>

# ==================== JWT SIGNING ====================
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# ==================== INTASEND (M-Pesa) ====================
INTASEND_PUBLISHABLE_KEY=<your-intasend-publishable-key>
INTASEND_SECRET_KEY=<your-intasend-secret-key>
INTASEND_API_URL=https://api.intasend.com
INTASEND_WEBHOOK_SECRET=<generate-a-secure-webhook-secret>

# ==================== M-PESA (Daraja) ====================
MPESA_ENABLED=true
MPESA_CONSUMER_KEY=<your-mpesa-consumer-key>
MPESA_CONSUMER_SECRET=<your-mpesa-consumer-secret>
MPESA_BUSINESS_SHORT_CODE=<your-business-short-code>
MPESA_PASS_KEY=<your-mpesa-pass-key>
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/webhook/mpesa
MPESA_ENVIRONMENT=production
MPESA_QUEUE_TIMEOUT=30s
MPESA_RESULT_URL=https://yourdomain.com/api/v1/webhook/mpesa

# ==================== EMAIL (SMTP) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<your-email@gmail.com>
SMTP_PASSWORD=<your-app-password>
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=InvoiceFast

# ==================== KRA e-TIMS ====================
KRA_ENABLED=true
KRA_API_URL=https://api.kra.go.ke
KRA_API_KEY=<your-kra-api-key>
KRA_BRANCH_CODE=<your-branch-code>
KRA_DEVICE_ID=<your-device-id>
KRA_BRANCH_ID=<your-branch-id>

# ==================== REDIS (Optional - Recommended for production) ====================
REDIS_URL=redis://localhost:6379

# ==================== RATE LIMITING ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60s

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_FILE=/var/log/invoicefast/server.log

# ==================== ALLOWED ORIGINS ====================
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ==================== BASE URL ====================
BASE_URL=https://yourdomain.com