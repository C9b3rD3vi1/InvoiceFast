# InvoiceFast Development Environment
# Use this for local development with SQLite

# ==================== SERVER ====================
PORT=8082
GIN_MODE=debug

# ==================== DATABASE (SQLITE - For Development) ====================
DB_DRIVER=sqlite3
DB_DSN=./data/invoicefast.db

# SQLite settings (single connection for dev)
DB_MAX_OPEN_CONNS=1
DB_MAX_IDLE_CONNS=1

# ==================== SECURITY KEYS (CRITICAL) ====================
# These must be at least 32 characters for encryption to work
JWT_SECRET=dev-jwt-token-change-in-production-minimum32chars!
ENCRYPTION_KEY=dev-encryption-key-change-in-production32!!

# ==================== JWT SIGNING ====================
JWT_EXPIRY_HOURS=72
JWT_REFRESH_EXPIRY_DAYS=30

# ==================== INTASEND (M-Pesa) ====================
INTASEND_PUBLISHABLE_KEY=dev_pub_test
INTASEND_SECRET_KEY=dev_sec_test
INTASEND_API_URL=https://sandbox.intasend.com
INTASEND_WEBHOOK_SECRET=dev_webhook_secret_change

# ==================== EMAIL (SMTP) ====================
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USERNAME=dev@ethereal.email
SMTP_PASSWORD=dev_password
FROM_EMAIL=dev@invoicefast.local
FROM_NAME=InvoiceFast Dev

# ==================== CALLBACKS ====================
CALLBACK_URL=http://localhost:8082/api/v1/webhook/intasend

# ==================== M-PESA (Daraja) - Disabled for Dev ====================
MPESA_ENABLED=false

# ==================== KRA e-TIMS - Disabled for Dev ====================
KRA_ENABLED=false

# ==================== REDIS (Optional) ====================
# REDIS_URL=redis://localhost:6379

# ==================== RATE LIMITING ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60s

# ==================== LOGGING ====================
LOG_LEVEL=debug
LOG_FILE=./server.log

# ==================== ALLOWED ORIGINS ====================
ALLOWED_ORIGINS=http://localhost:8082,http://localhost:3000